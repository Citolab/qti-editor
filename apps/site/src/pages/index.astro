---
import '../style.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QTI Editor</title>
    <meta
      name="description"
      content="QTI Editor is a composable editor for assessment authoring with framework-ready integration guides."
    />
  </head>
  <body
    class="min-h-screen font-['Avenir_Next','Segoe_UI',sans-serif] text-slate-800"
    style="background: radial-gradient(circle at 10% 10%, #fce7d6 0%, transparent 38%), radial-gradient(circle at 90% 0%, #e4d7f0 0%, transparent 35%), #f9f7f4;"
  >
    <main class="relative z-10 mx-auto max-w-[980px] px-5 pt-16 pb-20">
      <section class="rounded-3xl border border-[#e5ddd1] bg-[#fffdf8] px-8 py-12 shadow-[0_18px_55px_rgba(15,118,110,0.08)]">
        <h1 class="m-0 text-5xl font-bold text-[#449b44]">
          QTI Editor
        </h1>
        <h2 class="mt-2 text-[1.25rem] font-semibold text-slate-700">For modern assessment authoring</h2>
        <p class="text-slate-600 leading-relaxed mt-5">
          A composable authoring experience for QTI interactions. Usable as a standalone editor or integrated into your stack of choice. Check out the docs for more details and framework-specific guides to get started.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            class="inline-block rounded-full bg-[#449b44] px-[1.2rem] py-[0.72rem] font-semibold text-white no-underline transition-colors hover:bg-[#3a8639]"
            href="/docs">Read documentation</a
          >
          <a
            class="inline-block rounded-full border border-[#e5ddd1] bg-white px-[1.2rem] py-[0.72rem] font-semibold text-[#449b44] no-underline"
            href="/docs/frameworks/react">See React guide</a
          >
          <a
            class="inline-block rounded-full border border-[#e5ddd1] bg-white px-[1.2rem] py-[0.72rem] font-semibold text-[#449b44] no-underline"
            href="/docs/frameworks/angular">See Angular guide</a
          >
        </div>
      </section>

      <section class="mt-8 rounded-2xl border border-[#e5ddd1] bg-white p-4" aria-label="Interactive editor demo">
        <h2 class="mt-0 mb-3 text-[1.05rem]">Live Editor Demo</h2>
        <qti-editor-app class="block max-h-[80vh] overflow-y-auto"></qti-editor-app>
      </section>

      <section class="mt-8 grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-4" aria-label="Highlights">
        <article class="rounded-2xl border border-[#e5ddd1] bg-white p-4">
          <h2 class="mt-0 text-[1.05rem]">Framework examples</h2>
          <p class="mb-0 text-slate-600 leading-relaxed">
            Start from React and Angular integration pages with package setup and component wiring.
          </p>
        </article>
        <article class="rounded-2xl border border-[#e5ddd1] bg-white p-4">
          <h2 class="mt-0 text-[1.05rem]">QTI focused</h2>
          <p class="mb-0 text-slate-600 leading-relaxed">
            Build authoring workflows around QTI interactions with a shared package architecture.
          </p>
        </article>
        <article class="rounded-2xl border border-[#e5ddd1] bg-white p-4">
          <h2 class="mt-0 text-[1.05rem]">Docs-first onboarding</h2>
          <p class="mb-0 text-slate-600 leading-relaxed">
            Keep implementation and API guidance close to examples to speed up adoption.
          </p>
        </article>
      </section>
    </main>
    <script>
      import '../lib/register-qti-editor.ts';
    </script>
  </body>
</html>
