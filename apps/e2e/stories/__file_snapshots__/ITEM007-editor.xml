<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0p1_v1p0.xsd" identifier="ITEM007" title="Sleepvraag - opties boven" adaptive="false" time-dependent="false" xml:lang="en">
  <qti-response-declaration identifier="RESPONSE" cardinality="multiple" base-type="directedPair">
    <qti-correct-response>
      <qti-value>left_vermogen right_watt</qti-value>
      <qti-value>left_druk right_pascal</qti-value>
      <qti-value>left_frequentie right_hertz</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-outcome-declaration identifier="MAXSCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>1</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-item-body xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0">
    <p>Koppel het natuurkundige verschijnsel aan de juiste eenheid:</p>
    <qti-match-interaction response-identifier="RESPONSE">
      <qti-simple-match-set>
        <qti-simple-associable-choice identifier="left_vermogen" match-max="1">
          <p>Vermogen</p>
        </qti-simple-associable-choice>
        <qti-simple-associable-choice identifier="left_druk" match-max="1">
          <p>Druk</p>
        </qti-simple-associable-choice>
        <qti-simple-associable-choice identifier="left_frequentie" match-max="1">
          <p>Frequentie</p>
        </qti-simple-associable-choice>
      </qti-simple-match-set>
      <qti-simple-match-set>
        <qti-simple-associable-choice identifier="right_watt" match-max="1">
          <p>watt (W)</p>
        </qti-simple-associable-choice>
        <qti-simple-associable-choice identifier="right_pascal" match-max="1">
          <p>pascal (Pa)</p>
        </qti-simple-associable-choice>
        <qti-simple-associable-choice identifier="right_hertz" match-max="1">
          <p>hertz (Hz)</p>
        </qti-simple-associable-choice>
      </qti-simple-match-set>
    </qti-match-interaction>
    <p>
      <img src="/qti/kennisnet/resources/icons-physics.png" alt="Eenheden"/>
    </p>
    <qti-rubric-block use="scoring" view="scorer" class="qti-rubric-block">
      <qti-content-body>
        <p>Vermogen → watt (W)</p>
        <p>Druk → pascal (Pa)</p>
        <p>Frequentie → hertz (Hz)</p>
      </qti-content-body>
    </qti-rubric-block>
  </qti-item-body>
  <qti-response-processing template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct"/>
</qti-assessment-item>