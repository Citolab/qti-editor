<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0p1_v1p0.xsd" identifier="ITEM014" title="Volgordevraag (verticaal)" adaptive="false" time-dependent="false" xml:lang="en">
  <qti-response-declaration identifier="RESPONSE" cardinality="ordered" base-type="identifier">
    <qti-correct-response>
      <qti-value>num_1</qti-value>
      <qti-value>num_sqrt2</qti-value>
      <qti-value>num_pi</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-outcome-declaration identifier="MAXSCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>1</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-item-body xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0">
    <p>Sorteer de volgende getallen van klein naar groot:</p>
    <qti-order-interaction response-identifier="RESPONSE" class="qti-vertical">
      <qti-simple-choice identifier="num_sqrt2">
        <p>√2 (≈ 1,414)</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="num_1">
        <p>1</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="num_pi">
        <p>π (≈ 3,14159)</p>
      </qti-simple-choice>
    </qti-order-interaction>
    <qti-rubric-block use="scoring" view="scorer" class="qti-rubric-block">
      <qti-content-body>
        <p>Correcte volgorde: 1 → √2 → π</p>
      </qti-content-body>
    </qti-rubric-block>
  </qti-item-body>
  <qti-response-processing template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct"/>
</qti-assessment-item>