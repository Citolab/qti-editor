{
  "name": "@qti-editor/app",
  "version": "0.1.0",
  "description": "QTI Editor Demo Application - ProseKit editor with QTI support",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "yalc:add": "yalc add @qti-components/base @qti-components/interactions @qti-components/prosemirror @qti-components/theme @qti-components/utilities",
    "preview": "vite preview"
  },
  "dependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/lucide": "^1.2.90",
    "@lit/context": "^1.1.6",
    "@qti-components/base": "file:.yalc/@qti-components/base",
    "@qti-components/interactions": "file:.yalc/@qti-components/interactions",
    "@qti-components/prosemirror": "file:.yalc/@qti-components/prosemirror",
    "@qti-components/theme": "file:.yalc/@qti-components/theme",
    "@qti-components/utilities": "file:.yalc/@qti-components/utilities",
    "@qti-editor/context-qti-assessment-item": "workspace:*",
    "@qti-editor/plugin-editor-context": "workspace:*",
    "@qti-editor/plugin-editor-events": "workspace:*",
    "@qti-editor/plugin-qti-attributes": "workspace:*",
    "@qti-editor/plugin-qti-code": "workspace:*",
    "@qti-editor/plugin-qti-interactions": "workspace:*",
    "@qti-editor/plugin-toolbar": "workspace:*",
    "@qti-editor/prosemirror-block-select-plugin": "workspace:*",
    "lit": "^3.0.0",
    "prosekit": "^0.17.0",
    "prosemirror-menu": "^1.2.0",
    "@qti-editor/context-qti-composer": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20.0.0",
    "autoprefixer": "^10.4.23",
    "daisyui": "^5.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
