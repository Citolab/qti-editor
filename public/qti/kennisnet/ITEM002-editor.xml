<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0p1_v1p0.xsd" identifier="ITEM002" title="Meerkeuzevraag meerdere antwoorden" adaptive="false" time-dependent="false" xml:lang="en">
  <qti-response-declaration identifier="RESPONSE" cardinality="multiple" base-type="identifier">
    <qti-correct-response>
      <qti-value>choice1</qti-value>
      <qti-value>choice2</qti-value>
      <qti-value>choice4</qti-value>
    </qti-correct-response>
  </qti-response-declaration>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-outcome-declaration identifier="MAXSCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>1</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-item-body xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0">
    <qti-choice-interaction max-choices="0" response-identifier="RESPONSE" shuffle="true">
      <qti-prompt>
        <p>Welke van de volgende landen zijn volledig door één enkel ander land ingesloten?</p>
      </qti-prompt>
      <qti-simple-choice identifier="choice1">
        <p>Lesotho</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="choice2">
        <p>San Marino</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="choice3">
        <p>Bolivia</p>
      </qti-simple-choice>
      <qti-simple-choice identifier="choice4">
        <p>Vaticaanstad</p>
      </qti-simple-choice>
    </qti-choice-interaction>
    <p>
      <img src="/qti/kennisnet/resources/world-map.jpg" alt="Wereldkaart"/>
    </p>
    <qti-rubric-block use="scoring" view="scorer" class="qti-rubric-block">
      <qti-content-body>
        <p>Lesotho ligt volledig binnen Zuid-Afrika</p>
        <p>San Marino en Vaticaanstad liggen volledig binnen Italië</p>
        <p>Bolivia is niet ingesloten</p>
      </qti-content-body>
    </qti-rubric-block>
  </qti-item-body>
  <qti-response-processing template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct"/>
</qti-assessment-item>
