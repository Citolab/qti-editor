{
  "name": "@qti-editor/plugin-qti-interactions",
  "version": "0.1.0",
  "description": "ProseMirror plugin for QTI elements - framework-agnostic, works with vanilla ProseMirror, Tiptap, Remirror, ProseKit, etc.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./prosekit": "./src/prosekit.ts"
  },
  "peerDependencies": {
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-view": "^1.31.0",
    "prosekit": "^0.17.0"
  },
  "peerDependenciesMeta": {
    "prosemirror-model": {
      "optional": false
    },
    "prosemirror-state": {
      "optional": false
    },
    "prosemirror-view": {
      "optional": true
    },
    "prosekit": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc",
    "yalc:add": "yalc add @qti-components/base @qti-components/interactions @qti-components/prosemirror @qti-components/theme @qti-components/utilities"
  },
  "dependencies": {
    "@qti-components/base": "file:.yalc/@qti-components/base",
    "@qti-components/interactions": "file:.yalc/@qti-components/interactions",
    "@qti-components/prosemirror": "file:.yalc/@qti-components/prosemirror",
    "@qti-components/theme": "file:.yalc/@qti-components/theme",
    "@qti-components/utilities": "file:.yalc/@qti-components/utilities",
    "prosemirror-keymap": "^1.2.0",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
