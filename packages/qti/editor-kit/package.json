{
  "name": "@qti-editor/qti-editor-kit",
  "version": "0.1.0",
  "description": "Supported QTI editor-kit assembly surfaces for ProseMirror and ProseKit consumers",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./code": "./src/code/index.ts",
    "./editor-context": "./src/editor-context/index.ts",
    "./events": "./src/events/index.ts",
    "./interactions": "./src/interactions/index.ts",
    "./interactions/prosekit": "./src/interactions/prosekit.ts",
    "./item-context": "./src/item-context/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
