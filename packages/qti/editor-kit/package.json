{
  "name": "@qti-editor/qti-editor-kit",
  "version": "0.1.0",
  "description": "Supported QTI editor-kit assembly surfaces for ProseMirror and ProseKit consumers",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./code": {
      "types": "./dist/code/index.d.ts",
      "default": "./dist/code/index.js"
    },
    "./editor-context": {
      "types": "./dist/editor-context/index.d.ts",
      "default": "./dist/editor-context/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    },
    "./interactions": {
      "types": "./dist/interactions/index.d.ts",
      "default": "./dist/interactions/index.js"
    },
    "./interactions/prosekit": {
      "types": "./dist/interactions/prosekit.d.ts",
      "default": "./dist/interactions/prosekit.js"
    },
    "./item-context": {
      "types": "./dist/item-context/index.d.ts",
      "default": "./dist/item-context/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@qti-components/base": "1.4.1",
    "@qti-components/interactions": "1.10.1",
    "@qti-components/theme": "1.1.0",
    "@qti-components/utilities": "1.1.0",
    "@qti-editor/core": "workspace:*",
    "@qti-editor/interaction-choice": "workspace:*",
    "@qti-editor/interaction-extended-text": "workspace:*",
    "@qti-editor/interaction-inline-choice": "workspace:*",
    "@qti-editor/interaction-match": "workspace:*",
    "@qti-editor/interaction-select-point": "workspace:*",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/interaction-text-entry": "workspace:*",
    "@qti-editor/prosemirror-attributes-ui-prosekit": "workspace:*",
    "lit": "^3.3.2",
    "prosekit": "^0.18.4",
    "prosemirror-keymap": "^1.2.0",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.0"
  },
  "peerDependencies": {
    "prosekit": "^0.18.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
