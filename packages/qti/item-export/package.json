{
  "name": "@qti-editor/qti-item-export",
  "version": "0.1.0",
  "description": "ProseMirror → QTI 3.0 single assessment item export.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/qti/item-export"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pm-qti-item": {
      "types": "./dist/pm-qti-item.d.ts",
      "default": "./dist/pm-qti-item.js"
    },
    "./pm-xml": {
      "types": "./dist/pm-xml.d.ts",
      "default": "./dist/pm-xml.js"
    }
  },
  "scripts": {
    "pretypecheck": "pnpm --dir ../../.. build:workspace-deps && pnpm --filter @qti-editor/core build",
    "build": "pnpm --filter @qti-editor/core build && tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-editor/core": "workspace:*",
    "prosemirror-model": "^1.25.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
