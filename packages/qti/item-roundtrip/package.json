{
  "name": "@qti-editor/qti-item-roundtrip",
  "version": "1.0.0",
  "description": "Compose the QTI 3.0 item <-> ProseMirror roundtrip: import a QTI item (string or URL) into a ProseMirror document and export a ProseMirror document back to a QTI 3.0 assessment item.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/qti/item-roundtrip"
  },
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-components/transformers": "^1.6.4",
    "@qti-editor/core": "workspace:*",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/qti3-item-import": "workspace:*"
  },
  "peerDependencies": {
    "prosemirror-model": "^1.25.4"
  },
  "devDependencies": {
    "prosemirror-model": "^1.25.4",
    "typescript": "^5.0.0"
  }
}
