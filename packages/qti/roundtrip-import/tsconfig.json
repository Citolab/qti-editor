{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "moduleResolution": "bundler",
    "paths": {
      "@qti-editor/core": ["../../qti/core/dist/index.d.ts"],
      "@qti-editor/core/composer": ["../../qti/core/dist/composer/index.d.ts"],
      "@qti-editor/core/interactions/composer": ["../../qti/core/dist/interactions/composer.d.ts"],
      "@qti-editor/interfaces": ["../../interfaces/dist/index.d.ts"],
      "@qti-editor/qti-item-divider": ["../../qti/item-divider/dist/index.d.ts"],
      "@qti-editor/qti-item-divider/*": ["../../qti/item-divider/dist/*"],
      "@qti-editor/prosemirror-plugins": ["../../extensions/prosemirror/dist/index.d.ts"],
      "@qti-editor/prosekit-integration": ["../../extensions/prosekit/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.browser.test.ts"]
}
