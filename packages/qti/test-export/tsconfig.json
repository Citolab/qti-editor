{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "@qti-editor/qti-item-export": ["../../qti/item-export/dist/index.d.ts"],
      "@qti-editor/core/composer": ["../../qti/core/dist/composer/index.d.ts"],
      "@qti-editor/qti-item-export/pm-qti-item": ["../../qti/item-export/dist/pm-qti-item.d.ts"],
      "@qti-editor/qti-item-export/pm-xml": ["../../qti/item-export/dist/pm-xml.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
