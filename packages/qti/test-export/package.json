{
  "name": "@qti-editor/qti-test-export",
  "version": "0.1.0",
  "description": "ProseMirror → QTI 3.0 assessment test export (multiple items).",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/qti/test-export"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pm-qti-test": {
      "types": "./dist/pm-qti-test.d.ts",
      "default": "./dist/pm-qti-test.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @qti-editor/qti-item-export build && tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-editor/core": "workspace:*",
    "@qti-editor/qti-item-export": "workspace:*",
    "prosemirror-model": "^1.25.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
