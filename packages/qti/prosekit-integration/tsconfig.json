{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "@qti-editor/interactions": ["../../prosemirror/interactions/dist/index.d.ts"],
      "@qti-editor/interactions/associate": ["../../prosemirror/interactions/dist/associate/index.d.ts"],
      "@qti-editor/interactions/choice": ["../../prosemirror/interactions/dist/choice/index.d.ts"],
      "@qti-editor/interactions/extended-text": ["../../prosemirror/interactions/dist/extended-text/index.d.ts"],
      "@qti-editor/interactions/gap-match": ["../../prosemirror/interactions/dist/gap-match/index.d.ts"],
      "@qti-editor/interactions/hottext": ["../../prosemirror/interactions/dist/hottext/index.d.ts"],
      "@qti-editor/interactions/inline-choice": ["../../prosemirror/interactions/dist/inline-choice/index.d.ts"],
      "@qti-editor/interactions/match": ["../../prosemirror/interactions/dist/match/index.d.ts"],
      "@qti-editor/interactions/order": ["../../prosemirror/interactions/dist/order/index.d.ts"],
      "@qti-editor/interactions/select-point": ["../../prosemirror/interactions/dist/select-point/index.d.ts"],
      "@qti-editor/interactions/shared": ["../../prosemirror/interactions/dist/shared/index.d.ts"],
      "@qti-editor/interactions/shared/*": ["../../prosemirror/interactions/dist/shared/*"],
      "@qti-editor/interactions/text-entry": ["../../prosemirror/interactions/dist/text-entry/index.d.ts"],
      "@qti-editor/qti-item-export/pm-qti-item": ["../../qti/item-export/dist/pm-qti-item.d.ts"],
      "@qti-editor/qti-item-export/pm-xml": ["../../qti/item-export/dist/pm-xml.d.ts"],
      "@qti-editor/qti-test-export/pm-qti-test": ["../../qti/test-export/dist/pm-qti-test.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
