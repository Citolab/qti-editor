{
  "name": "@qti-editor/core",
  "version": "1.7.0",
  "description": "QTI semantics, composer registry, and XML export orchestration for QTI Editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/qti/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./composer": {
      "types": "./dist/composer/index.d.ts",
      "default": "./dist/composer/index.js"
    },
    "./interactions/composer": {
      "types": "./dist/interactions/composer.d.ts",
      "default": "./dist/interactions/composer.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-editor/interfaces": "1.5.0",
    "@qti-editor/interaction-associate": "1.4.2",
    "@qti-editor/interaction-choice": "1.4.2",
    "@qti-editor/interaction-extended-text": "1.4.3",
    "@qti-editor/interaction-gap-match": "1.3.2",
    "@qti-editor/interaction-hottext": "1.3.3",
    "@qti-editor/interaction-inline-choice": "1.5.2",
    "@qti-editor/interaction-match": "1.4.2",
    "@qti-editor/interaction-order": "0.9.1",
    "@qti-editor/interaction-select-point": "1.3.3",
    "@qti-editor/interaction-shared": "1.6.1",
    "@qti-editor/interaction-text-entry": "1.3.3",
    "@qti-editor/qti-item-divider": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
