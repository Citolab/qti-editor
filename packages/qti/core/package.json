{
  "name": "@qti-editor/core",
  "version": "1.8.0",
  "description": "QTI semantics, composer registry, and XML export orchestration for QTI Editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/qti/core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./composer": {
      "types": "./dist/composer/index.d.ts",
      "default": "./dist/composer/index.js"
    },
    "./interactions/composer": {
      "types": "./dist/interactions/composer.d.ts",
      "default": "./dist/interactions/composer.js"
    }
  },
  "scripts": {
    "pretypecheck": "pnpm --dir ../../.. build:workspace-deps",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-editor/interfaces": "1.5.0",
    "@qti-editor/interactions": "workspace:*",
    "@qti-editor/qti-item-divider": "workspace:*",
    "@qti-editor/qti-rubric-block": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
