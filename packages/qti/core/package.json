{
  "name": "@qti-editor/core",
  "version": "0.3.0",
  "description": "QTI semantics, composer registry, and XML export orchestration for QTI Editor",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./composer": {
      "types": "./dist/composer/index.d.ts",
      "default": "./dist/composer/index.js"
    },
    "./interactions/composer": {
      "types": "./dist/interactions/composer.d.ts",
      "default": "./dist/interactions/composer.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-editor/interfaces": "workspace:*",
    "@qti-editor/interaction-associate": "workspace:*",
    "@qti-editor/interaction-choice": "workspace:*",
    "@qti-editor/interaction-extended-text": "workspace:*",
    "@qti-editor/interaction-hottext": "workspace:*",
    "@qti-editor/interaction-inline-choice": "workspace:*",
    "@qti-editor/interaction-match": "workspace:*",
    "@qti-editor/interaction-order": "workspace:*",
    "@qti-editor/interaction-select-point": "workspace:*",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/interaction-text-entry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
