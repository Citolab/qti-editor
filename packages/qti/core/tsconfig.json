{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "@qti-editor/interaction-shared": ["../../interactions/shared/dist/index.d.ts"],
      "@qti-editor/interaction-shared/*": ["../../interactions/shared/dist/*"],
      "@qti-editor/interactions": ["../../interactions/barrel/dist/index.d.ts"],
      "@qti-editor/interactions/associate": ["../../interactions/barrel/dist/associate/index.d.ts"],
      "@qti-editor/interactions/choice": ["../../interactions/barrel/dist/choice/index.d.ts"],
      "@qti-editor/interactions/extended-text": ["../../interactions/barrel/dist/extended-text/index.d.ts"],
      "@qti-editor/interactions/gap-match": ["../../interactions/barrel/dist/gap-match/index.d.ts"],
      "@qti-editor/interactions/hottext": ["../../interactions/barrel/dist/hottext/index.d.ts"],
      "@qti-editor/interactions/inline-choice": ["../../interactions/barrel/dist/inline-choice/index.d.ts"],
      "@qti-editor/interactions/match": ["../../interactions/barrel/dist/match/index.d.ts"],
      "@qti-editor/interactions/order": ["../../interactions/barrel/dist/order/index.d.ts"],
      "@qti-editor/interactions/select-point": ["../../interactions/barrel/dist/select-point/index.d.ts"],
      "@qti-editor/interactions/shared": ["../../interactions/barrel/dist/shared/index.d.ts"],
      "@qti-editor/interactions/shared/*": ["../../interactions/barrel/dist/shared/*"],
      "@qti-editor/interactions/text-entry": ["../../interactions/barrel/dist/text-entry/index.d.ts"],
      "@qti-editor/qti-item-divider": ["../item-divider/dist/index.d.ts"],
      "@qti-editor/qti-item-divider/*": ["../item-divider/dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
