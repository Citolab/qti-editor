{
  "name": "@qti-editor/qti-package",
  "version": "0.1.0",
  "description": "QTI 3.0 content package (.zip) builder — IMS manifest + assessment-test + items + assets.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/qti/package"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-editor/core": "workspace:*",
    "@qti-editor/qti-test-export": "workspace:*",
    "jszip": "^3.10.1",
    "prosemirror-model": "^1.25.4"
  },
  "devDependencies": {
    "@qti-editor/qti-roundtrip-import": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
