{
  "name": "@qti-editor/interactions",
  "version": "1.0.0",
  "description": "Umbrella QTI interaction package with tree-shakeable subpath exports",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/prosemirror/interactions"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./associate": {
      "types": "./dist/associate/index.d.ts",
      "default": "./dist/associate/index.js"
    },
    "./associate/*": {
      "types": "./dist/associate/*",
      "default": "./dist/associate/*"
    },
    "./choice": {
      "types": "./dist/choice/index.d.ts",
      "default": "./dist/choice/index.js"
    },
    "./choice/*": {
      "types": "./dist/choice/*",
      "default": "./dist/choice/*"
    },
    "./extended-text": {
      "types": "./dist/extended-text/index.d.ts",
      "default": "./dist/extended-text/index.js"
    },
    "./extended-text/*": {
      "types": "./dist/extended-text/*",
      "default": "./dist/extended-text/*"
    },
    "./gap-match": {
      "types": "./dist/gap-match/index.d.ts",
      "default": "./dist/gap-match/index.js"
    },
    "./gap-match/*": {
      "types": "./dist/gap-match/*",
      "default": "./dist/gap-match/*"
    },
    "./hottext": {
      "types": "./dist/hottext/index.d.ts",
      "default": "./dist/hottext/index.js"
    },
    "./hottext/*": {
      "types": "./dist/hottext/*",
      "default": "./dist/hottext/*"
    },
    "./inline-choice": {
      "types": "./dist/inline-choice/index.d.ts",
      "default": "./dist/inline-choice/index.js"
    },
    "./inline-choice/*": {
      "types": "./dist/inline-choice/*",
      "default": "./dist/inline-choice/*"
    },
    "./match": {
      "types": "./dist/match/index.d.ts",
      "default": "./dist/match/index.js"
    },
    "./match/*": {
      "types": "./dist/match/*",
      "default": "./dist/match/*"
    },
    "./order": {
      "types": "./dist/order/index.d.ts",
      "default": "./dist/order/index.js"
    },
    "./order/*": {
      "types": "./dist/order/*",
      "default": "./dist/order/*"
    },
    "./select-point": {
      "types": "./dist/select-point/index.d.ts",
      "default": "./dist/select-point/index.js"
    },
    "./select-point/*": {
      "types": "./dist/select-point/*",
      "default": "./dist/select-point/*"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    },
    "./shared/*": {
      "types": "./dist/shared/*",
      "default": "./dist/shared/*"
    },
    "./text-entry": {
      "types": "./dist/text-entry/index.d.ts",
      "default": "./dist/text-entry/index.js"
    },
    "./text-entry/*": {
      "types": "./dist/text-entry/*",
      "default": "./dist/text-entry/*"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-components/associate-interaction": "^1.0.1",
    "@qti-components/base": "^1.4.3",
    "@qti-components/choice-interaction": "^1.1.4",
    "@qti-components/hottext-interaction": "^1.1.3",
    "@qti-components/inline-choice-interaction": "^1.1.3",
    "@qti-components/interactions": "1.10.3",
    "@qti-components/interactions-core": "^1.1.4",
    "@qti-components/order-interaction": "^1.1.2",
    "@qti-components/select-point-interaction": "^1.0.1",
    "@qti-components/text-entry-interaction": "^1.0.0",
    "@qti-components/utilities": "^1.3.3",
    "@qti-editor/interfaces": "workspace:*",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.31.0"
  },
  "peerDependencies": {
    "lit": "^3.3.1",
    "prosekit": "^0.20.0"
  },
  "peerDependenciesMeta": {
    "prosekit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@qti-editor/interaction-associate": "workspace:*",
    "@qti-editor/interaction-choice": "workspace:*",
    "@qti-editor/interaction-extended-text": "workspace:*",
    "@qti-editor/interaction-gap-match": "workspace:*",
    "@qti-editor/interaction-hottext": "workspace:*",
    "@qti-editor/interaction-inline-choice": "workspace:*",
    "@qti-editor/interaction-match": "workspace:*",
    "@qti-editor/interaction-order": "workspace:*",
    "@qti-editor/interaction-select-point": "workspace:*",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/interaction-text-entry": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
