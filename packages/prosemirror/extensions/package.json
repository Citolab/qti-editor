{
  "name": "@qti-editor/prosemirror",
  "version": "0.1.0",
  "description": "Pure ProseMirror plugins for QTI Editor - block selection and virtual cursor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./block-select": {
      "types": "./dist/block-select/index.d.ts",
      "default": "./dist/block-select/index.js"
    },
    "./virtual-cursor": {
      "types": "./dist/virtual-cursor/index.d.ts",
      "default": "./dist/virtual-cursor/index.js"
    },
    "./node-attrs-sync": {
      "types": "./dist/node-attrs-sync/index.d.ts",
      "default": "./dist/node-attrs-sync/index.js"
    },
    "./paste-semantic-html": {
      "types": "./dist/paste-semantic-html/index.d.ts",
      "default": "./dist/paste-semantic-html/index.js"
    },
    "./local-storage-doc-persistence-extension": {
      "types": "./dist/local-storage-doc-persistence-extension/index.d.ts",
      "default": "./dist/local-storage-doc-persistence-extension/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "prosemirror-commands": "^1.5.0",
    "prosemirror-history": "^1.4.0",
    "prosemirror-menu": "^1.2.0",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.0",
    "prosemirror-view": "^1.31.0"
  },
  "peerDependencies": {
    "prosekit": "^0.18.4"
  },
  "peerDependenciesMeta": {
    "prosekit": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
