{
  "name": "@qti-editor/interaction-extended-text",
  "description": "QTI extended text interaction schemas, components, commands, and composer",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-components/extended-text-interaction": "^1.0.1",
    "@qti-components/interactions": "1.10.1",
    "@qti-components/utilities": "1.1.0",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/interfaces": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "lit": "^3.3.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
