{
  "name": "@qti-editor/interaction-text-entry",
  "description": "QTI text-entry interaction schemas, components, commands, and composer",
  "version": "1.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/prosemirror/interaction-text-entry"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-components/interactions": "1.10.1",
    "@qti-components/text-entry-interaction": "^1.0.0",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/interfaces": "workspace:*",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.31.0"
  },
  "peerDependencies": {
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "lit": "^3.3.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
