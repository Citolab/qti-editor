{
  "name": "@qti-editor/interaction-inline-choice",
  "description": "QTI inline-choice interaction schemas, components, and commands",
  "version": "1.5.2",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/interactions/inline-choice"
  },
  "type": "module",
  "sideEffects": [
    "**/register.js",
    "**/register.ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@qti-components/inline-choice-interaction": "^1.1.3",
    "@qti-components/interactions": "1.10.1",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/interfaces": "workspace:*",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.31.0"
  },
  "peerDependencies": {
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "lit": "^3.3.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
