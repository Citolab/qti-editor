{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "useDefineForClassFields": false,
    "allowImportingTsExtensions": false,
    "moduleResolution": "bundler",
    "paths": {
      "@qti-editor/interaction-shared": ["../../shared/dist/index.d.ts"],
      "@qti-editor/interaction-shared/*": ["../../shared/dist/*"],
      "@qti-editor/interaction-hottext": ["./src/index.ts"],
      "@qti-editor/interaction-hottext/*": ["./src/*"]
    },
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/index.ts", "src/register.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "**/*.stories.ts", "src/stories/**", "node_modules", "dist"]
}
