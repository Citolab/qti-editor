{
  "name": "@qti-editor/prosekit-extensions",
  "version": "0.1.0",
  "description": "Reusable ProseKit extensions for QTI Editor (strong, em, list)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/prosekit/extensions"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./marks": {
      "types": "./dist/strong-em.d.ts",
      "default": "./dist/strong-em.js"
    },
    "./list": {
      "types": "./dist/list.d.ts",
      "default": "./dist/list.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1"
  },
  "peerDependencies": {
    "prosekit": "^0.21.3"
  },
  "peerDependenciesMeta": {
    "prosekit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
