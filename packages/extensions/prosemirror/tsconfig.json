{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "allowImportingTsExtensions": false,
    "moduleResolution": "bundler",
    "paths": {
      "@qti-editor/interfaces": ["../../interfaces/dist/index.d.ts"],
      "@qti-editor/interaction-shared": ["../../interactions/shared/dist/index.d.ts"],
      "@qti-editor/interaction-shared/*": ["../../interactions/shared/dist/*"],
      "@qti-editor/prosemirror-plugins": ["./src/index.ts"],
      "@qti-editor/prosemirror-plugins/*": ["./src/*"]
    },
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "**/*.stories.ts", "node_modules", "dist"]
}
