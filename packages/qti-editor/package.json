{
  "name": "qti-editor",
  "version": "0.1.0",
  "description": "QTI Editor - A complete toolkit for building QTI-based rich text editors",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core.ts",
    "./core/attributes": "./src/core/attributes.ts",
    "./core/code": "./src/core/code.ts",
    "./core/composer": "./src/core/composer.ts",
    "./core/editor-context": "./src/core/editor-context.ts",
    "./core/events": "./src/core/events.ts",
    "./core/interactions": "./src/core/interactions.ts",
    "./core/interactions/prosekit": "./src/core/interactions-prosekit.ts",
    "./core/item-context": "./src/core/item-context.ts",
    "./extensions": "./src/extensions.ts",
    "./extensions/attributes": "./src/extensions/attributes.ts",
    "./lit": "./src/lit.ts",
    "./coco": "./src/coco.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@qti-editor/coco": "workspace:*",
    "@qti-editor/core": "workspace:*",
    "@qti-editor/extensions": "workspace:*",
    "@qti-editor/lit": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.0.0",
    "prosekit": "^0.17.0"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
