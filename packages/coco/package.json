{
  "name": "@qti-editor/coco",
  "version": "0.1.0",
  "description": "Single web component bundle for a full QTI editor",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --paths null",
    "typecheck": "tsc --paths null --noEmit"
  },
  "dependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/lucide": "^1.2.96",
    "@lit/context": "^1.1.6",
    "@qti-components/base": "1.2.0",
    "@qti-components/interactions": "1.8.0",
    "@qti-components/theme": "1.1.0",
    "@qti-components/utilities": "1.1.0",
    "@qti-editor/core": "workspace:*",
    "@qti-editor/interactions-qti-choice": "workspace:*",
    "@qti-editor/interactions-qti-extended-text": "workspace:*",
    "@qti-editor/interactions-qti-match": "workspace:*",
    "@qti-editor/interactions-qti-select-point": "workspace:*",
    "@qti-editor/prosemirror-block-select": "workspace:*",
    "@qti-editor/prosemirror-node-attrs-sync": "workspace:*",
