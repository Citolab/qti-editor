{
  "name": "@qti-editor/core",
  "version": "0.1.0",
  "description": "Compatibility re-export layer for legacy QTI Editor core entrypoints",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./attributes": "./src/attributes/index.ts",
    "./code": "./src/code/index.ts",
    "./composer": "./src/composer/index.ts",
    "./editor-context": "./src/editor-context/index.ts",
    "./events": "./src/events/index.ts",
    "./interactions": "./src/interactions/index.ts",
    "./interactions/composer": "./src/interactions/composer.ts",
    "./interactions/prosekit": "./src/interactions/prosekit.ts",
    "./item-context": "./src/item-context/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "yalc:add": "yalc add @qti-components/interactions"
  },
  "dependencies": {
    "@qti-editor/qti-editor-kit": "workspace:*",
    "@qti-editor/qti-core": "workspace:*",
    "@qti-editor/prosemirror-attributes": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
