{
  "name": "@qti-editor/ui",
  "private": true,
  "version": "0.1.0",
  "description": "Canonical UI source for QTI Editor blocks and vendored ProseKit-shaped components",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/button": "./src/components/button/index.js",
    "./components/image-upload-popover": "./src/components/image-upload-popover/index.js",
    "./components/toolbar": "./src/components/toolbar/index.js",
    "./components/slash-menu": "./src/components/slash-menu/index.js",
    "./components/sample/sample-uploader": "./src/components/sample/sample-uploader.js",
    "./components/attributes-panel": "./src/components/attributes-panel/index.ts",
    "./components/code-panel": "./src/components/code-panel/index.ts",
    "./components/composer": "./src/components/composer/index.ts",
    "./components/composer-metadata-form": "./src/components/composer-metadata-form/index.ts",
    "./components/interaction-insert-menu": "./src/components/interaction-insert-menu/index.ts",
    "./components/items-navigator": "./src/components/items-navigator/index.ts",
    "./components/items-gutter": "./src/components/items-gutter/index.ts",
    "./components/convert-menu": "./src/components/convert-menu/index.ts",
    "./components/choice-attributes-editor": "./src/components/choice-attributes-editor/index.ts",
    "./components/text-entry-attributes-editor": "./src/components/text-entry-attributes-editor/index.ts",
    "./components/extended-text-attributes-editor": "./src/components/extended-text-attributes-editor/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "registry:transform": "node scripts/transform-imports.mjs",
    "registry:build": "node scripts/transform-imports.mjs && cd dist && npx shadcn@latest build ./registry.json --output ./public/r",
    "registry:serve": "npx serve dist/public -p 4100 --cors"
  },
  "dependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@iconify-json/lucide": "^1.2.98",
    "@lit/context": "^1.1.6",
    "@qti-editor/core": "workspace:*",
    "@qti-editor/interaction-associate": "workspace:*",
    "@qti-editor/interaction-choice": "workspace:*",
    "@qti-editor/interaction-extended-text": "workspace:*",
    "@qti-editor/interaction-gap-match": "workspace:*",
    "@qti-editor/interaction-hottext": "workspace:*",
    "@qti-editor/interaction-inline-choice": "workspace:*",
    "@qti-editor/interaction-match": "workspace:*",
    "@qti-editor/interaction-order": "workspace:*",
    "@qti-editor/interaction-select-point": "workspace:*",
    "@qti-editor/interaction-shared": "workspace:*",
    "@qti-editor/interaction-text-entry": "workspace:*",
    "@qti-editor/prosekit-integration": "workspace:*",
    "@qti-editor/prosemirror-attributes": "workspace:*",
    "@qti-editor/prosemirror-attributes-ui-prosekit": "workspace:*",
    "@qti-editor/qti-item-divider": "workspace:*",
    "lit": "^3.3.2",
    "prosekit": "^0.20.0",
    "prosemirror-state": "^1.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "serve": "^14.0.0",
    "typescript": "^5.0.0"
  }
}
