        "lit",
        "prosekit",
        "@qti-editor/core",
        "@qti-editor/qti-core",
        "@qti-editor/interaction-choice",
        "@qti-editor/prosemirror-attributes-ui-prosekit"
      ],
      "files": [
        {
          "path": "components/blocks/attributes-panel/index.ts",
          "source": "src/components/blocks/attributes-panel/index.ts",
          "module": "@qti-editor/ui/components/blocks/attributes-panel",
          "type": "registry:component"
        },
        {
          "path": "examples/attributes-panel/index.ts",
          "source": "src/examples/attributes-panel/index.ts",
          "type": "registry:example"
        },
        {
          "path": "examples/attributes-panel/extension.ts",
