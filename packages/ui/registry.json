        "lit",
        "prosekit",
        "@qti-editor/core",
        "@qti-editor/prosemirror-attributes",
        "@qti-editor/prosemirror-attributes-ui-prosekit"
      ],
      "registryDependencies": ["qti-choice-attributes-editor", "qti-text-entry-attributes-editor"],
