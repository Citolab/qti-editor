{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@qti-editor/ui": ["./src/index.ts"],
      "@qti-editor/ui/*": ["./src/*"],
      "@qti-editor/core/composer": ["../qti/core/src/composer/index.ts"],
      "@qti-editor/core/interactions/composer": ["../qti/core/src/interactions/composer.ts"],
      "@qti-editor/interaction-choice": ["../prosemirror/interaction-choice/dist/index.d.ts"],
      "@qti-editor/interaction-extended-text": ["../prosemirror/interaction-extended-text/dist/index.d.ts"],
      "@qti-editor/interaction-match": ["../prosemirror/interaction-match/dist/index.d.ts"],
      "@qti-editor/interaction-select-point": ["../prosemirror/interaction-select-point/dist/index.d.ts"],
      "@qti-editor/interaction-text-entry": ["../prosemirror/interaction-text-entry/dist/index.d.ts"],
      "@qti-editor/prosemirror-attributes": ["../prosemirror/attributes/dist/index.d.ts"],
      "@qti-editor/prosemirror-attributes-ui-prosekit": ["../prosemirror/attributes-ui-prosekit/dist/index.d.ts"],
    }
  },
  "include": ["src/**/*.ts", "src/**/*.js"]
}
