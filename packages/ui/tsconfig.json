{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "useDefineForClassFields": false,
    "paths": {
      "@qti-editor/ui": ["./src/index.ts"],
      "@qti-editor/ui/*": ["./src/*"],
      "@qti-editor/core/composer": ["../qti/core/src/composer/index.ts"],
      "@qti-editor/core/interactions/composer": ["../qti/core/src/interactions/composer.ts"],
      "@qti-editor/interactions": ["../interactions/barrel/src/index.ts"],
      "@qti-editor/interactions/associate": ["../interactions/barrel/src/associate/index.ts"],
      "@qti-editor/interactions/choice": ["../interactions/barrel/src/choice/index.ts"],
      "@qti-editor/interactions/extended-text": ["../interactions/barrel/src/extended-text/index.ts"],
      "@qti-editor/interactions/gap-match": ["../interactions/barrel/src/gap-match/index.ts"],
      "@qti-editor/interactions/hottext": ["../interactions/barrel/src/hottext/index.ts"],
      "@qti-editor/interactions/inline-choice": ["../interactions/barrel/src/inline-choice/index.ts"],
      "@qti-editor/interactions/match": ["../interactions/barrel/src/match/index.ts"],
      "@qti-editor/interactions/order": ["../interactions/barrel/src/order/index.ts"],
      "@qti-editor/interactions/select-point": ["../interactions/barrel/src/select-point/index.ts"],
      "@qti-editor/interactions/shared": ["../interactions/shared/src/index.ts"],
      "@qti-editor/interactions/shared/*": ["../interactions/shared/src/*"],
      "@qti-editor/interactions/text-entry": ["../interactions/barrel/src/text-entry/index.ts"],
      "@qti-editor/interaction-associate": ["../interactions/associate/src/index.ts"],
      "@qti-editor/interaction-choice": ["../interactions/choice/src/index.ts"],
      "@qti-editor/interaction-extended-text": ["../interactions/extended-text/src/index.ts"],
      "@qti-editor/interaction-gap-match": ["../interactions/gap-match/src/index.ts"],
      "@qti-editor/interaction-hottext": ["../interactions/hottext/src/index.ts"],
      "@qti-editor/interaction-inline-choice": ["../interactions/inline-choice/src/index.ts"],
      "@qti-editor/interaction-match": ["../interactions/match/src/index.ts"],
      "@qti-editor/interaction-order": ["../interactions/order/src/index.ts"],
      "@qti-editor/interaction-select-point": ["../interactions/select-point/src/index.ts"],
      "@qti-editor/interaction-shared": ["../interactions/shared/src/index.ts"],
      "@qti-editor/interaction-shared/*": ["../interactions/shared/src/*"],
      "@qti-editor/interaction-text-entry": ["../interactions/text-entry/src/index.ts"],
      "@qti-editor/interfaces": ["../interfaces/src/index.ts"],
      "@qti-editor/qti-item-divider": ["../qti/item-divider/src/index.ts"],
      "@qti-editor/qti-item-divider/*": ["../qti/item-divider/src/*"],
      "@qti-editor/qti-item-export/pm-qti-item": ["../qti/item-export/src/pm-qti-item.ts"],
      "@qti-editor/qti-item-export/pm-xml": ["../qti/item-export/src/pm-xml.ts"],
      "@qti-editor/qti-test-export/pm-qti-test": ["../qti/test-export/src/pm-qti-test.ts"],
      "@qti-editor/prosemirror-attributes": ["../extensions/prosemirror/src/attributes/index.ts"],
      "@qti-editor/prosemirror-attributes-ui": ["../extensions/prosemirror/src/attributes-ui/index.ts"],
    }
  },
  "include": ["src/**/*.ts", "src/**/*.js"]
}
