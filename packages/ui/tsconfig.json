{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false,
    "useDefineForClassFields": false,
    "paths": {
      "@qti-editor/ui": ["./src/index.ts"],
      "@qti-editor/ui/*": ["./src/*"],
      "@qti-editor/core/composer": ["../qti/core/src/composer/index.ts"],
      "@qti-editor/core/interactions/composer": ["../qti/core/src/interactions/composer.ts"],
      "@qti-editor/interactions": ["../prosemirror/interactions/src/index.ts"],
      "@qti-editor/interactions/associate": ["../prosemirror/interactions/src/associate/index.ts"],
      "@qti-editor/interactions/choice": ["../prosemirror/interactions/src/choice/index.ts"],
      "@qti-editor/interactions/extended-text": ["../prosemirror/interactions/src/extended-text/index.ts"],
      "@qti-editor/interactions/gap-match": ["../prosemirror/interactions/src/gap-match/index.ts"],
      "@qti-editor/interactions/hottext": ["../prosemirror/interactions/src/hottext/index.ts"],
      "@qti-editor/interactions/inline-choice": ["../prosemirror/interactions/src/inline-choice/index.ts"],
      "@qti-editor/interactions/match": ["../prosemirror/interactions/src/match/index.ts"],
      "@qti-editor/interactions/order": ["../prosemirror/interactions/src/order/index.ts"],
      "@qti-editor/interactions/select-point": ["../prosemirror/interactions/src/select-point/index.ts"],
      "@qti-editor/interactions/shared": ["../prosemirror/interactions/src/shared/index.ts"],
      "@qti-editor/interactions/shared/*": ["../prosemirror/interactions/src/shared/*"],
      "@qti-editor/interactions/text-entry": ["../prosemirror/interactions/src/text-entry/index.ts"],
      "@qti-editor/qti-item-export/pm-qti-item": ["../qti/item-export/src/pm-qti-item.ts"],
      "@qti-editor/qti-item-export/pm-xml": ["../qti/item-export/src/pm-xml.ts"],
      "@qti-editor/qti-test-export/pm-qti-test": ["../qti/test-export/src/pm-qti-test.ts"],
      "@qti-editor/prosemirror-attributes": ["../prosemirror/attributes/src/index.ts"],
      "@qti-editor/prosemirror-attributes-ui": ["../prosemirror/attributes-ui/src/index.ts"],
    }
  },
  "include": ["src/**/*.ts", "src/**/*.js"]
}
