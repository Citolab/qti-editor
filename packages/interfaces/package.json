{
  "name": "@qti-editor/interfaces",
  "description": "Contract types for the QTI editor — zero runtime dependencies",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Citolab/qti-editor",
    "directory": "packages/interfaces"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
