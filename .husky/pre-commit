#!/usr/bin/env sh
# Strip yalc deps from staged package.json files before they enter a commit.
# After the commit, run `pnpm yalc:add` to restore yalc dev mode.

staged_pkg_jsons=$(git diff --cached --name-only --diff-filter=ACM -- '*package.json')
yalc_in_index=false
for f in $staged_pkg_jsons; do
  if git show ":$f" 2>/dev/null | grep -q '"file:\.yalc/'; then
    yalc_in_index=true
    break
  fi
done

if [ "$yalc_in_index" = "true" ]; then
  echo ""
  echo "🧹 pre-commit: yalc file: deps detected in staged package.json files."
  echo "   Running 'yalc retreat --all' and re-staging clean versions..."
  yalc retreat --all || exit 1
  modified=$(git diff --name-only -- '*package.json')
  if [ -n "$modified" ]; then
    echo "$modified" | xargs git add
  fi
  echo "✅ yalc removed from index. Commit will proceed with clean package.json."
  echo "   To restore yalc dev mode after commit: pnpm yalc:add"
  echo ""
fi

# Run the same lint check CI runs so drift can't sneak past a local commit.
# Mirrors `.github/workflows/ci.yml` (Lint step: `pnpm lint:check`).
echo "🔍 pre-commit: running eslint ."
if ! eslint .; then
  echo ""
  echo "❌ Lint failed. Fix errors above (or run 'pnpm lint' for autofix), then re-commit."
  echo "   To bypass in an emergency: git commit --no-verify"
  exit 1
fi
