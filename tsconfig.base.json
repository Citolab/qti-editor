{
  "compilerOptions": {
    "target": "ES2020",
    "experimentalDecorators": true,
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@qti-editor/core": [
        "packages/qti/core/src/index.ts"
      ],
      "@qti-editor/core/composer": [
        "packages/qti/core/src/composer/index.ts"
      ],
      "@qti-editor/core/interactions/composer": [
        "packages/qti/core/src/interactions/composer.ts"
      ],
      "@qti-editor/qti-roundtrip-export": [
        "packages/qti/roundtrip-export/src/index.ts"
      ],
      "@qti-editor/qti-roundtrip-export/*": [
        "packages/qti/roundtrip-export/src/*"
      ],
      "@qti-editor/qti-roundtrip-import": [
        "packages/qti/roundtrip-import/src/index.ts"
      ],
      "@qti-editor/qti-roundtrip-import/*": [
        "packages/qti/roundtrip-import/src/*"
      ],
      "@qti-editor/prosekit-integration/save-qti": [
        "packages/qti/prosekit-integration/src/save-qti/index.ts"
      ],
      "@qti-editor/core/*": [
        "packages/qti/core/src/*"
      ],
      "@citolab/qti-editor-core": [
        "packages/qti/core/src/index.ts"
      ],
      "@citolab/qti-editor-core/*": [
        "packages/qti/core/src/*"
      ],
      "@citolab/qti-editor-plugin-slash-menu": [
        "packages/plugin-slash-menu/src/index.ts"
      ],
      "@citolab/qti-editor-plugin-slash-menu/*": [
        "packages/plugin-slash-menu/src/*"
      ],
      "@citolab/qti-editor-plugin-qti-import": [
        "packages/plugin-qti-import/src/index.ts"
      ],
      "@citolab/qti-editor-plugin-qti-import/*": [
        "packages/plugin-qti-import/src/*"
      ],
      "@qti-editor/plugin-toolbar": [
        "packages/plugin-toolbar/src/index.ts"
      ],
      "@qti-editor/plugin-toolbar/*": [
        "packages/plugin-toolbar/src/*"
      ],
      "@qti-editor/plugin-side-panel": [
        "packages/plugin-side-panel/index.ts"
      ],
      "@qti-editor/prosemirror-plugins": [
        "packages/prosemirror/extensions/src/index.ts"
      ],
      "@qti-editor/prosemirror-attributes": [
        "packages/prosemirror/attributes/src/index.ts"
      ],
      "@qti-editor/prosemirror-attributes-ui": [
        "packages/prosemirror/attributes-ui/src/index.ts"
      ],
      "@qti-editor/ui": [
        "packages/ui/src/index.ts"
      ],
      "@qti-editor/ui/*": [
        "packages/ui/src/*"
      ],
      "@qti-editor/prosekit-integration": [
        "packages/qti/prosekit-integration/src/index.ts"
      ],
      "@qti-editor/prosekit-integration/code": [
        "packages/qti/prosekit-integration/src/code/index.ts"
      ],
      "@qti-editor/prosekit-integration/editor-context": [
        "packages/qti/prosekit-integration/src/editor-context/index.ts"
      ],
      "@qti-editor/prosekit-integration/events": [
        "packages/qti/prosekit-integration/src/events/index.ts"
      ],
      "@qti-editor/prosekit-integration/interactions/prosekit": [
        "packages/qti/prosekit-integration/src/interactions/prosekit.ts"
      ],
      "@qti-editor/prosekit-integration/item-context": [
        "packages/qti/prosekit-integration/src/item-context/index.ts"
      ],
      "@qti-editor/prosekit-integration/save-xml": [
        "packages/qti/prosekit-integration/src/save-xml/index.ts"
      ],
      "@qti-editor/prosekit-integration/*": [
        "packages/qti/prosekit-integration/src/*"
      ],
      "@qti-editor/prosemirror-plugins/block-select": [
        "packages/prosemirror/extensions/src/block-select/index.ts"
      ],
      "@qti-editor/prosemirror-plugins/virtual-cursor": [
        "packages/prosemirror/extensions/src/virtual-cursor/index.ts"
      ],
      "@qti-editor/prosemirror-plugins/node-attrs-sync": [
        "packages/prosemirror/extensions/src/node-attrs-sync/index.ts"
      ],
      "@qti-editor/prosemirror-plugins/paste-semantic-html": [
        "packages/prosemirror/extensions/src/paste-semantic-html/index.ts"
      ],
      
      "@qti-editor/interaction-choice": [
        "packages/prosemirror/interaction-choice/src/index.ts"
      ],
      "@qti-editor/interaction-extended-text": [
        "packages/prosemirror/interaction-extended-text/src/index.ts"
      ],
      "@qti-editor/interaction-hottext": [
        "packages/prosemirror/interaction-hottext/src/index.ts"
      ],
      "@qti-editor/interaction-inline-choice": [
        "packages/prosemirror/interaction-inline-choice/src/index.ts"
      ],
      "@qti-editor/interaction-match": [
        "packages/prosemirror/interaction-match/src/index.ts"
      ],
      "@qti-editor/interaction-order": [
        "packages/prosemirror/interaction-order/src/index.ts"
      ],
      "@qti-editor/interaction-select-point": [
        "packages/prosemirror/interaction-select-point/src/index.ts"
      ],
      "@qti-editor/interaction-text-entry": [
        "packages/prosemirror/interaction-text-entry/src/index.ts"
      ],
      "@qti-editor/interfaces": [
        "packages/interfaces/src/index.ts"
      ],
      "@qti-editor/interaction-shared": [
        "packages/prosemirror/interaction-shared/src/index.ts"
      ],
      "@qti-editor/interaction-shared/*": [
        "packages/prosemirror/interaction-shared/src/*"
      ]
    }
  }
}
