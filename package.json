{
  "name": "@qti-editor/root",
  "pnpm": {
    "overrides": {
      "prosekit": "^0.21.3",
      "prosemirror-commands": "^1.7.1",
      "prosemirror-history": "^1.5.0",
      "prosemirror-inputrules": "^1.5.1",
      "prosemirror-keymap": "^1.2.3",
      "prosemirror-model": "^1.25.8",
      "prosemirror-schema-basic": "^1.2.4",
      "prosemirror-schema-list": "^1.5.1",
      "prosemirror-state": "^1.4.4",
      "prosemirror-view": "^1.41.9"
    }
  },
  "version": "0.1.0",
  "description": "QTI Editor built with ProseMirror, ProseKit, and modular plugins",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @qti-editor/prosekit-app dev",
    "dev:prosekit-app": "pnpm --filter @qti-editor/prosekit-app dev",
    "dev:prosekit-item": "pnpm --filter @qti-editor/prosekit-item dev",
    "dev:prosemirror-item": "pnpm --filter @qti-editor/prosemirror-item dev",
    "site:dev": "pnpm --filter @qti-editor/site dev",
    "build": "pnpm build:packages && pnpm --filter @qti-editor/prosekit-app build",
    "build:workspace-deps": "QTI_SKIP_CORE_PREBUILD=1 pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/prose-extensions\" --filter \"./packages/prose-qti\" run build",
    "build:core-deps": "QTI_SKIP_CORE_PREBUILD=1 pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/prose-extensions\" --filter \"./packages/prose-qti\" run build",
    "deploy:build": "pnpm deploy:build:site && pnpm deploy:build:editor",
    "deploy:build:site": "pnpm build:packages && pnpm --filter @qti-editor/site build && pnpm build-storybook && node scripts/prepare-hosting-site.mjs",
    "deploy:build:editor": "pnpm build:packages && pnpm --filter @qti-editor/prosekit-app build && node scripts/prepare-hosting-editor.mjs",
    "preview": "pnpm --filter @qti-editor/prosekit-app preview",
    "firebase:serve": "pnpm deploy:build && firebase emulators:start --only hosting",
    "firebase:deploy:hosting": "pnpm deploy:build && firebase deploy --only hosting",
    "firebase:deploy:site": "pnpm deploy:build:site && firebase deploy --only hosting:site",
    "firebase:deploy:editor": "pnpm deploy:build:editor && firebase deploy --only hosting:editor",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules",
    "build:packages": "QTI_SKIP_CORE_PREBUILD=1 pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/prose-extensions\" --filter \"./packages/prose-qti\" run build && QTI_SKIP_CORE_PREBUILD=1 pnpm -r --sort --workspace-concurrency=1 --filter \"./packages/prose-qti-ui\" run build",
    "registry:build": "pnpm --filter @citolab/prose-qti-ui registry:build",
    "registry:serve": "pnpm --filter @citolab/prose-qti-ui registry:serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "release": "multi-semantic-release --ignore-private-packages --deps.bump=inherit",
    "qti-components:update": "pnpm -r up \"@qti-components/*\" \"@citolab/qti-components\"",
    "qti-overrides:status": "node scripts/qti-local-overrides-sync.mjs status",
    "qti-overrides:sync": "node scripts/qti-local-overrides-sync.mjs sync",
    "qti-overrides:install": "node scripts/qti-local-overrides-sync.mjs sync && pnpm install",
    "prepare": "husky",
    "yalc:add": "pnpm -r exec yalc restore && node scripts/yalc-overrides.mjs add",
    "yalc:remove-all": "pnpm -r exec yalc retreat --all && node scripts/yalc-overrides.mjs remove",
    "yalc:overrides:add": "node scripts/yalc-overrides.mjs add",
    "yalc:overrides:remove": "node scripts/yalc-overrides.mjs remove",
    "dev:linked": "node scripts/dev-linked.mjs",
    "yalc:init": "node scripts/yalc-init.mjs",
    "qti-overrides:snapshot": "node scripts/qti-local-overrides-sync.mjs snapshot",
    "preinstall": "node scripts/qti-overrides-preinstall.mjs"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.39.2",
    "@qti-components/theme": "https://pkg.pr.new/Citolab/qti-components/@qti-components/theme@6e2486ee2587932fcacf7f27182c994010d6c8a0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/web-components-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-wc": "^3.1.0",
    "fast-xml-parser": "^5.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lit": "^3.3.2",
    "multi-semantic-release": "^3.0.0",
    "playwright": "^1.58.2",
    "prosekit": "^0.21.3",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.8",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "remark-gfm": "^4.0.1",
    "semantic-release": "^24.0.0",
    "shadow-dom-testing-library": "^1.13.1",
    "storybook": "^10.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.1.9",
    "yalc": "1.0.0-pre.53"
  }
}
