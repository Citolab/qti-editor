{
  "name": "@qti-editor/root",
  "version": "0.1.0",
  "description": "QTI Editor built with Tiptap and modular plugins",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8",
  "scripts": {
    "dev": "pnpm --filter @qti-editor/app dev",
    "build": "pnpm build:packages && pnpm --filter @qti-editor/app build",
    "deploy:build": "pnpm registry:build && pnpm --filter @qti-editor/app build && pnpm build-storybook && node scripts/prepare-hosting.mjs",
    "preview": "pnpm --filter @qti-editor/app preview",
    "firebase:serve": "pnpm deploy:build && firebase emulators:start --only hosting",
    "firebase:deploy": "pnpm deploy:build && firebase deploy --only hosting",
    "build:packages": "pnpm -r --filter \"./packages/**\" run build",
    "registry:build": "pnpm --filter @qti-editor/ui registry:build",
    "registry:serve": "pnpm --filter @qti-editor/ui registry:serve",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "qti-components:status": "node scripts/qti-components-git-overrides.mjs status",
    "qti-components:sync": "node scripts/qti-components-git-overrides.mjs sync",
    "qti-components:install": "node scripts/qti-components-git-overrides.mjs sync && CI=true pnpm install --no-frozen-lockfile"
  },
  "dependencies": {
    "eslint-plugin-lit": "^2.2.1",
    "lit": "^3.0.0",
    "prosekit": "^0.18.4",
    "typescript": "^5.0.0",
    "vite": "^6.4.1"
  },
  "devDependencies": {
    "@qti-components/theme": "^1.3.1",
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.2",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/web-components-vite": "^10.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^10.2.8",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "storybook": "^10.2.8",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "qtiComponentsGitOverrides": {
    "@qti-components/interactions-core": "github:Citolab/qti-components#648154ec0c5b3dac8a5118ab450df3d6c508c8a3&path:/packages/interactions/core",
    "@qti-components/choice-interaction": "github:Citolab/qti-components#648154ec0c5b3dac8a5118ab450df3d6c508c8a3&path:/packages/interactions/choice-interaction"
  },
  "pnpm": {
    "overrides": {
      "@qti-components/interactions-core": "file:.qti-components-packs/648154ec0c5b3dac8a5118ab450df3d6c508c8a3/qti-components-interactions-core-1.1.0.tgz",
      "@qti-components/choice-interaction": "file:.qti-components-packs/648154ec0c5b3dac8a5118ab450df3d6c508c8a3/qti-components-choice-interaction-1.1.0.tgz"
    }
  }
}
