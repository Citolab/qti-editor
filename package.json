{
  "name": "@qti-editor/root",
  "version": "0.1.0",
  "description": "QTI Editor built with Tiptap and modular plugins",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @qti-editor/app dev",
    "build": "pnpm build:packages && pnpm --filter @qti-editor/app build",
    "preview": "pnpm --filter @qti-editor/app preview",
    "build:packages": "pnpm -r --filter \"./packages/**\" run build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "chrome:debug": "/Applications/Google\\ Chrome.app/Contents/MacOS/Google\\ Chrome --remote-debugging-port=9222 --user-data-dir=/tmp/chrome-remote-debug"
  },
  "dependencies": {
    "lit": "^3.0.0",
    "prosekit": "^0.17.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.19.2"
  }
}
