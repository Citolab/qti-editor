{
  "name": "@qti-editor/root",
  "version": "0.1.0",
  "description": "QTI Editor built with Tiptap and modular plugins",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8",
  "scripts": {
    "dev": "pnpm --filter @qti-editor/app dev",
    "build": "pnpm build:packages && pnpm --filter @qti-editor/app build",
    "preview": "pnpm --filter @qti-editor/app preview",
    "firebase:serve": "firebase emulators:start --only hosting",
    "firebase:deploy": "pnpm build && firebase deploy --only hosting",
    "build:packages": "pnpm -r --filter \"./packages/**\" run build",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "chrome:debug": "/Applications/Google\\ Chrome.app/Contents/MacOS/Google\\ Chrome --remote-debugging-port=9222 --user-data-dir=/tmp/chrome-remote-debug"
  },
  "dependencies": {
    "eslint-plugin-lit": "^2.2.1",
    "lit": "^3.0.0",
    "prosekit": "^0.17.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.19.2",
    "vite-tsconfig-paths": "^6.0.5"
  },
  "pnpm": {
    "overrides": {
      "@qti-components/interactions": "link:.yalc/@qti-components/interactions",
      "@qti-components/base": "link:.yalc/@qti-components/base",
      "@qti-components/prosemirror": "link:.yalc/@qti-components/prosemirror",
      "@qti-components/theme": "link:.yalc/@qti-components/theme",
      "@qti-components/utilities": "link:.yalc/@qti-components/utilities"
    }
  }
}
