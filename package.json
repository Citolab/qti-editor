{
  "name": "@qti-editor/root",
  "version": "0.1.0",
  "description": "QTI Editor built with ProseMirror, ProseKit, and modular plugins",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @qti-editor/app dev",
    "build": "pnpm build:packages && pnpm --filter @qti-editor/app build",
    "deploy:build": "pnpm deploy:build:site && pnpm deploy:build:editor",
    "deploy:build:site": "pnpm build:packages && pnpm registry:build && pnpm --filter @qti-editor/site build && pnpm build-storybook && node scripts/prepare-hosting-site.mjs",
    "deploy:build:editor": "pnpm build:packages && pnpm --filter @qti-editor/app build && node scripts/prepare-hosting-editor.mjs",
    "preview": "pnpm --filter @qti-editor/app preview",
    "firebase:serve": "pnpm deploy:build && firebase emulators:start --only hosting",
    "firebase:deploy:hosting": "pnpm deploy:build && firebase deploy --only hosting",
    "firebase:deploy:site": "pnpm deploy:build:site && firebase deploy --only hosting:site",
    "firebase:deploy:editor": "pnpm deploy:build:editor && firebase deploy --only hosting:editor",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules",
    "build:packages": "pnpm -r --filter \"./packages/**\" run build",
    "registry:build": "pnpm --filter @qti-editor/ui registry:build",
    "registry:serve": "pnpm --filter @qti-editor/ui registry:serve",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "release": "multi-semantic-release --ignore-private-packages",
    "qti-components:update": "pnpm -r up --latest @qti-components/interactions-core @qti-components/base @qti-components/theme @qti-components/base @qti-components/utilities @qti-components/choice-interaction @qti-components/inline-choice-interaction @qti-components/extended-text-interaction @qti-components/hottext-interaction @qti-components/choice-interaction @qti-components/extended-text-interaction @qti-components/match-interaction",
    "qti-overrides:status": "node scripts/qti-local-overrides-sync.mjs status",
    "qti-overrides:sync": "node scripts/qti-local-overrides-sync.mjs sync",
    "qti-overrides:install": "node scripts/qti-local-overrides-sync.mjs sync && pnpm install"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.2",
    "@qti-components/theme": "^1.3.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@storybook/addon-a11y": "^10.2.8",
    "@storybook/addon-docs": "^10.2.8",
    "@storybook/addon-vitest": "^10.2.8",
    "@storybook/web-components-vite": "^10.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-storybook": "^10.2.8",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.4.0",
    "lit": "^3.3.2",
    "multi-semantic-release": "^3.0.0",
    "playwright": "^1.58.2",
    "prosekit": "^0.20.0",
    "remark-gfm": "^4.0.1",
    "semantic-release": "^24.0.0",
    "storybook": "^10.2.8",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  }
}
